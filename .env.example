# ──────────────────────────────────────────────
# Virtual Office — variables de entorno de ejemplo
# Copia este fichero a .env y rellena los valores
# ──────────────────────────────────────────────

# Servidor
NODE_ENV=development
PORT=8080
LOG_LEVEL=debug

# Base de datos
DB_PATH=./data/virtual-office.db

# Sesión JWT (mínimo 32 caracteres)
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
SESSION_SECRET_PREVIOUS=
SESSION_TTL_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dominios Teimas permitidos para login con Google
TEIMAS_DOMAINS=teimas.com,teimas.es,teimassolutions.com

# Emails de super-admins iniciales (separados por coma)
ADMIN_EMAILS=

# URL pública del frontend (para OAuth redirect y CORS)
PUBLIC_BASE_URL=http://localhost:5173

# Reservas
INVITATION_TTL_DAYS=7
MAX_DESKS_PER_OFFICE=200
BOOKING_HORIZON_DAYS=60

# Mapas de oficina
OFFICE_MAPS_DIR=./data/maps
MAX_TMJ_BYTES=1048576
MAX_TILESET_BYTES=2097152
MAX_MAP_TOTAL_BYTES=10485760

# Backups automáticos
VO_BACKUP_DIR=./backups
VO_BACKUP_CRON=0 3 * * *

# Métricas Prometheus (Basic Auth)
BASIC_AUTH_METRICS_USER=
BASIC_AUTH_METRICS_PASS=

# Sentry (dejar vacío para desactivar)
SENTRY_DSN=
GIT_SHA=

# Solo para tests — no usar en producción
# TEST_AUTH=on

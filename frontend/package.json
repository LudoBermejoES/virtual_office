    "phaser": "^4.0.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.15.17",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^4.1.5"
  }
}

# ──────────────────────────────────────────────────────────────────
#  Runtime data (SQLite, mapas Tiled subidos, logs)
# ──────────────────────────────────────────────────────────────────
data/
!data/.gitkeep
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Logs (Winston + PM2)
logs/
*.log
pm2-*.log
pm2.pid
.pm2/

# ──────────────────────────────────────────────────────────────────
#  Tests
# ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
.vitest-cache/
.vitest/

# Playwright
playwright-report/
playwright/.cache/
test-results/
blob-report/
# Mantener baselines de regresión visual; ignorar solo los diffs/actuales
**/__diff_output__/
**/test-results/**

# ──────────────────────────────────────────────────────────────────
#  TypeScript
# ──────────────────────────────────────────────────────────────────
*.tsbuildinfo
.tsbuild/


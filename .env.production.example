# ──────────────────────────────────────────────
# Virtual Office — variables de entorno de PRODUCCIÓN
# Copia a .env en el servidor y rellena todos los valores
# NUNCA commitear este fichero con valores reales
# ──────────────────────────────────────────────

NODE_ENV=production
PORT=8080
LOG_LEVEL=info

DB_PATH=./data/virtual-office.db

SESSION_SECRET=genera-con-openssl-rand-base64-32
SESSION_SECRET_PREVIOUS=
SESSION_TTL_DAYS=7

GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

TEIMAS_DOMAINS=teimas.com,teimas.es,teimassolutions.com
ADMIN_EMAILS=tu-email@teimas.com

PUBLIC_BASE_URL=https://tu-dominio.com

INVITATION_TTL_DAYS=7
MAX_DESKS_PER_OFFICE=200
BOOKING_HORIZON_DAYS=60

OFFICE_MAPS_DIR=./data/maps
MAX_TMJ_BYTES=1048576
MAX_TILESET_BYTES=2097152
MAX_MAP_TOTAL_BYTES=10485760

VO_BACKUP_DIR=./backups
VO_BACKUP_CRON=0 3 * * *

BASIC_AUTH_METRICS_USER=metrics
BASIC_AUTH_METRICS_PASS=cambia-esto

SENTRY_DSN=https://...@sentry.io/...
GIT_SHA=
